# .env.example - Production Environment Variables Configuration

# --------------------------
# APPLICATION
# --------------------------
ENVIRONMENT=production
PORT=8000
API_V1_STR=/api/v1
# CORS_ORIGINS=http://localhost:3000,https://your-frontend.run.app

# --------------------------
# MARKET DATA (TwelveData)
# --------------------------
TWELVEDATA_API_KEY=your_twelvedata_api_key_here

# --------------------------
# EXECUTION (MetaTrader 5 Bridge / Webhook)
# --------------------------
MT5_WEBHOOK_SECRET=your_secret_for_local_ea_webhook
MT5_WEBHOOK_URL=http://your-local-ip:broker-port/webhook_endpoint

# --------------------------
# NEWS & SENTIMENT (Twitter)
# --------------------------
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# --------------------------
# DATABASE (PostgreSQL)
# --------------------------
# POSTGRES_URL=postgresql+asyncpg://user:password@hostname:5432/dbname

# --------------------------
# TIMING & ZONES
# --------------------------
DEFAULT_TIMEZONE=Asia/Makassar
