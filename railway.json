{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd mcp-backend && pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "cd mcp-backend && uvicorn main:app --host 0.0.0.0 --port $PORT",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "always"
  }
}